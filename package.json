{
	"name": "uitool-eproto-language",
	"displayName": "UITool EProto Language",
	"description": "",
	"version": "1.0.0",
	"engines": {
		"vscode": "^1.107.0"
	},
	"categories": [
		"Programming Languages"
	],
	"contributes": {
		"languages": [
			{
				"id": "eproto",
				"aliases": [
					"UITool EProto",
					"eproto"
				],
				"extensions": [
					".epr"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "eproto",
				"scopeName": "source.eproto",
				"path": "./syntaxes/eproto.tmLanguage.json"
			}
		],
		"commands": [
			{
				"command": "eproto.dumpCurrentLineState",
				"title": "EPR: Dump Current Line State"
			},
			{
				"command": "eproto.initDocument",
				"title": "EPR: Init EPR Document"
			},
			{
				"command": "eproto.compileCurrentFile",
				"title": "EPR: Compile Current EPR File"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "eproto.dumpCurrentLineState",
					"when": "editorLangId == 'eproto'"
				},
				{
					"command": "eproto.initDocument",
					"when": "editorLangId == 'eproto'"
				},
				{
					"command": "eproto.compileCurrentFile",
					"when": "editorLangId == 'eproto'"
				}
			]
		},
		"jsonValidation": [
			{
				"fileMatch": [
					"*.epr.json"
				],
				"url": "./schema/epr-project-schema.json"
			}
		],
		"configurationDefaults": {
			"[eproto]": {
				"files.encoding": "gbk"
			}
		}
	},
	"main": "./out/extension.js",
	"devDependencies": {
		"@types/mocha": "^10.0.0",
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.85.0",
		"@vscode/test-cli": "^0.0.8",
		"@vscode/test-electron": "^2.3.0",
		"mocha": "^10.0.0",
		"typescript": "^5.3.0"
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"test": "vscode-test",
		"clean:vscode-test": "node -e \"const fs=require('fs'); try { fs.rmSync('.vscode-test', { recursive: true, force: true }); console.log('cleaned .vscode-test'); } catch (e) { console.warn('skip cleaning .vscode-test:', e.code || e.message); }\"",
		"test:clean": "pnpm test && pnpm run clean:vscode-test"
	}
}