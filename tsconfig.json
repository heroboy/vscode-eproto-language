{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2024",
		"lib": [
			"ES2024"
		],
		"outDir": "out",
		"sourceMap": true,
		"strict": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"types": ["node", "mocha", "vscode"]
	},
	"include": ["src/**/*", "test/**/*"],
	"exclude": [
		"node_modules",
		".vscode-test",
		"schema"
	]
}