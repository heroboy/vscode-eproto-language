//聚宝盆的结构。看后面协议引用这个结构的地方。
struct JBPeng_Result
{
	//这个结构体是否有值。为true，后面的值才有效
	bool hasValue:1 = false;
	//赢取礼物的价值。可能是-1，表示赢取全部。
	int winValue:2;
	//实际赢取礼物的价值
	int actualWinValue:3;
	//实际礼物
	KVItem gifts:4[];
};
//服务器刷新一个场景的数据
//玩家进入会发送3个
message UpdatePlayerData:1 s2c
{
	//1,2,3 三个场景
	int scene:1;
	//背包内碎片数据。0-7的id。不是实际ks的礼物id。（在有保底配置的游戏里，id==8是保底碎片）
	//背包碎片数量<=6，当背包碎片>3个的时候，需要发送整理背包指令，手动选择3个。
	//否则不能下注
	//背包内会出现-1表示空位。
	//背包大小有2种情况，3或6。 3就是正常情况。6表示需要整理。
	//整理的时候需要bag[0]和bag[3], bag[1]和bag[4]，bag[2]和bat[5]，3组之间二选一的整理。
	int bag:2[];
	//新增字段，3或者4。 用于支持解锁额外背包格子。
	//1.这个字段表示的是当前背包的状态。有可能UpdateExtraBagPlayerData处于锁定状态，但这里是4。
	//2.在下面BetSuccess中，bagCount始终是最后收到的UpdatePlayerData里的数值。计算背包需要按照这个数值来。
	//3.上述bag的说明修改为：前bagCount为背包内的道具，后3个为额外的3个碎片。
	//        所以，当bagCount==3，bag大小为3或6，当6的时候，需要发送整理。
	//                  当bagCount==4, bag大小为4或7，当7的时候，需要发送整理。
	int bagCount:9 = 3;

	//是否首次
	bool first:3;

	//龙晶数量，龙晶数量==3个的时候，需要发送合成龙晶的指令
	int crystal:4;
	//龙晶还有多少秒过期
	int crystalExpireSeconds:5;
	int todayCrystal:6;
	//玩转盘用的能量
	int energy:7;
	//上一次龙晶合成的礼物id, -1或0表示没有
	int lastCombineGiftId:8;
};

//服务器发送，龙晶过期了。需要设置自己的龙晶=0
//只会在进入服务器的时候检查。在服务器内的时候不会过期。
message CrystalExpired:2  s2c
{
	//哪个场景的。
	int scene:1;
};

//当玩家背包碎片>3个，需要手动整理背包才能继续游戏
//整理背包，看上面关于怎么整理的说明
message UpdateMyBag:3  c2s
{
	int scene:1;
	// <= 3
	int bag:2[];
};

//整理背包成功
message UpdateMyBagSuccess:4  s2c
{
	int scene:1;
	int bag:2[];
	//3或者4
	int bagCount:3;
};

//整理背包失败
//明显的参数错误不会回复。例如: scene<=0, bag.length > 3等
message UpdateMyBagFailed:5  s2c
{
	//没有原因
};

//客户端发送合成龙晶
message CombineCrystal:6  c2s
{
	int scene:1;
};

//合成成功
message CombineCrystalSuccess:7  s2c
{
	int scene:1;
	//获得了哪个礼物。（这里的id时ks的礼物id）
	int giftId:2;
};

//合成失败
message CombineCrystalFailed:8  s2c
{

};

//客户端下注
message Bet:9  c2s
{
	int scene:1;
	//次数：1，10，100（首次游玩只能count==1）
	int count:2;
	//是否加倍
	bool isDouble:3;
	//背包整理策略
	//0 手动整理（只能在count==1的时候选择）,1 价值优先，2后来的优先
	int bagPolicy:4;
	/*
	    开启神龙积分玩法。
	    当false，则和以前一样正常玩，无论服务器是否开启神龙积分，都不允许掉落神龙积分。
	    当true，则表示要玩神龙积分模式。（注：当服务器不支持或没在活动期间设置为true，也不会下注失败）
	    接下来参考BetSuccess中注释，如果支持神龙积分模式。
	*/
	//不再被使用，服务器会忽略这个参数了
	bool _useDragonScore:5 = false;

	//使用“福”的盘数。需要保证，处在福活动中，并且福的数量足够(次数 * 价格 * 是否加倍)。
	//useFuCount必须<=count
	int _useFuCount_:6 = 0;
};

//下注失败
message BetFailed:10  s2c
{
	//明显的参数错误不回复。例如：scene不合法，count<0 , bagPolicy<0 , bagPoly>2等
	//1 钱不够，2次数不对，3背包策略不对，4需要整理背包，5需要合成龙晶,6. 首次，但是选择了double。
	//7 useFu>0但是活动已经结束了, 8参数错误useFuCount>count
	//16 需要选择是否兑换福，17 需要选择增量卡
	int reason:1;
};

//表示了一次击破
struct BetResult
{
	//掉落的碎片(碎片id都是[0,7]的数字)
	char fragments:5[3];
	//掉落、合成、整理后的背包内碎片
	//如果是自动整理，则bag大小是3（或者4，解锁格子情况下），如果不是自动整理bag大小是6（或者7，解锁格子情况下）
	char bag:6[];
	//奖励类型。[0,24]的数字。
	//0-23分别是：碎片0 x2，碎片0 x3，碎片0 x4,，碎片1 x2 ... 
	//上面8种碎片，每种为2,3,4个，一共3*8=24种中奖情况。
	//24 表示，无组合碎片。
	char rewardType:7;
	//当rewardType==24 && fallback==true的时候，触发的是保底碎片。bag和fragments中会出现2个保底碎片用于合成
	bool fallback:8;

	//宝藏碎片：掉落的宝藏碎片0-8。-1表示没掉落。
	char dropPuzzlePiece:9;
	//掉落的精魄，已经是乘以了倍率了。如果精魄满了，则上面dropPuzzlePiece=8，掉落LV3碎片，并且后续精魄变成0.    
	short dropPuzzleJp:10;
	//掉落的“福”
	short _dropFu_:11 = 0;

	int giftId:12;
	int giftCount:13;
};



message BetSuccess:11  s2c
{
	//数组长度对应了count
	BetResult results:1[];
	//表示掉落的龙晶
	int crystal:3;
	//整个结束后，玩家的这个场景数据
	UpdatePlayerData next:2;
	//掉落宝藏碎片精魄的倍率1,2,3
	char dropPuzzleJpMul:4 = 1;

	/*
		神龙积分模式新增。
		0 表示正常结算了，和之前一样。
		1 表示需要进行礼物积分兑换。
		    这时候，服务器发送BetSuccess只是临时告诉你游戏结果，并没有修改任何玩家数据。
		    客户端需要发送ExchangeDragonScore选择哪些礼物兑换成神龙积分，服务器才进行最终的结算。
		    客户端这时候只能发送ExchangeDragonScore，在没有完成兑换之前，发送其它指令Bet,BetSky都会出错。
		    如果这时候客户端断线重入了，服务器会再次发送这个BetSuccess，提醒你需要ExchangeDragonScore。
		    如果下注后，实际获得的礼物没有可以兑换的积分，则服务器会直接发送dragonScoreMode=0的BetSuccess。
	*/
	//不再被使用，服务器会忽略这个参数
	int _dragonScoreMode:5 = 0;
	bool isDouble:6;

	//增量卡：第几局游戏中掉落了. -1表示没掉落。
	//如果掉落了则要发送ChooseAccCard来选择卡。不选择不能继续进行游戏。
	int dropAccCardIndex:7 = -1;
	//今天的第几张
	int dropAccCardTodayCount:10 = 0;
	//第几局使用了当前的增量卡
	int useAccCardIndex:8 = -1;
	//具体使用的卡的giftId
	int useAccCard:9 = 0;

	//实际加的排行榜分数
	int realAddBillboardScore:11 = 0;
	//加的排行榜统计分数，用于计算每日限制，不包含随机部分的。
	int addBillboardDayScore:12=0;

	//“福”：类似于上面的_dragonScoreMode，1的时候，表示需要发送Fu_ExchnageGiftToFu，才能完成整个下注。
	//注：和DragonScore不同，断线或逃跑之后，会自动结算。不用处理断线逃跑的问题。
	int _fuMode_:13 = 0;

	int _useFuCount_:14 = 0;

	//排行榜4活动的分数。如果当前不在活动期间则数组长度是0.
	//否则内容为 [加的基础分，随机分，幸运分，连续幸运分]
	int rank4Scores:15[];
	//聚宝盆玩法的结果
	JBPeng_Result jbp:16;

	//同上rank4, 但是是3个数字    [加的基础分，随机分，幸运分]    
	int rank5Scores:17[];
};

struct _DragonScoreExchangeItem
{
	int giftId:1;
	int count:2;
};

//神龙积分模式中，客户端发送这个选择哪些礼物进行兑换。
message _ExchangeDragonScore:45  c2s
{
	//要兑换哪些礼物变为神龙积分。
	_DragonScoreExchangeItem items:1[];
};

message _ExchangeDragonScoreSuccess:46  s2c
{
	//原BetSuccess中的内容，表示实际游戏的结果
	BetSuccess bs:1;
	//获得了多少神龙积分
	int getDragonScore:2;
	//获得了多少神龙降临礼物
	int getGiftCount:3;
	//最终你的神龙积分是多少
	int nowDragonScore:4;
};

message _ExchangeDragonScoreFailed:47  s2c
{
	//1 现在不能发送ExchangeDragonScore，2 参数错误，items中有非法的giftId或者count太多了或者giftId重复了。
	int reason:1;
};

struct _DragonScoreHistoryItem
{
	string date:1;
	//gifts 中 用了count个礼物id换取了score个神龙积分
	//getScore 表示增加了多少分，redeemGiftCount表示增加的多少礼物并扣了相应的分数，nowScore最终神龙积分
	//注：如果这局游戏产生了神龙积分，则RankListItem的chipex中会有个类似gifts的字段。
	//格式1:  {type:"getdragonscore" ,gifts:[{id:123,count:1,score:10}],nowScore:123,redeemGiftCount:1,getScore:1111}
	//其它礼物兑换，活动结束后，首次登录房间自动兑换的礼物。myScore兑换前我的积分。gifts实际兑换的礼物
	//格式2：{type:"dragonscore_finalredeem",gifts:[{id:123,count:1,score:10}}],myScore:123}
	string chipex:2;
};


message _QueryDragonScoreHistory:48  c2s
{

};

message _QueryDragonScoreHistorySuccess:49  s2c
{
	_DragonScoreHistoryItem items:1[];     
};
message _QueryDragonScoreHistoryFailed:50  s2c
{
	int reason:1;
};


