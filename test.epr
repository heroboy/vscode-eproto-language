//转转盘
message Roll:18  c2s
{
	//场景
	int scene:2;
	//想要转的挡位。1，2，3
	//挡位其实没得选择，和你的当前能量有关。如果填错，会失败的。
	int level:1;
};

message RollSuccess:19  s2c
{
	int scene:2;
	int level:1;
	//选中了哪一个0-7，序号
	int rollIndex:3;
	//中的礼物id
	int rollGiftId:4;
	//转完后你剩下的能量。不发next了，只有能量是有变化的。
	int nextEnergy:5;
};

message RollFailed:20  s2c
{
	//明显程序写错的失败不回复这个协议。例如scene写错了。
	//原因. 1能量不够，2没开通
	int reason:1;
};


//系统公告
message GiftMessage:21 s2c
{
	//可能是假数据，userid=0
	int userid:5;
	string nickname:6;
	//类型：0击破，1合成龙晶，2转盘，3藏宝拼图小奖，4藏宝拼图大奖，5兑换神龙降临count个
	//          6表示使用增量卡，>1000中超大奖礼物，这时候只有items有意义。
	// 其中》1000的时候，从1000开始按顺序是：常规击破、转盘、拼图、神龙降临、排行榜奖励、增量卡生效、每日福利


	//对于藏宝拼图，下面的count应该没意义。
	//对于5，下面只有count有意义，表示神龙降临的个数
	//对于6，scene有用，items中有一项，其中v已经加1了
	int type:1;
	//击破次数
	int count:2;
	//场景1，2，3
	int scene:3;
	//获得奖励。其中，k是ks的礼物id，v是数量
	KVItem items:4[];

	int id:7;
};


struct RollHistoryItem:22 
{
	//1,2,3
	int scene:1;
	//2024-07-05 15:47:46
	string date:2;
	//{"type":"roll","scene":1,"level":2,"giftIndex":5,"giftId":123445}
	string chipex:3;
};

