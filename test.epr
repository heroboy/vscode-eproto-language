{
	char scene:3;//场景
	string date:1;//日期
	string chipex:2;//json格式的明细
};

//查询我的兑换历史
message QueryMyPuzzleRedeemHistory:37 c2s
{

};

message QueryMyPuzzleRedeemHistorySuccess:38 s2c
{
	PuzzleRedeemHistoryItem data:1[];
