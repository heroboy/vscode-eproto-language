	Rank5_RankListItem items:2[];
};

//玩家收到邮件后，请求服务器领取邮件奖励
message Rank5_RedeemReward:133   c2s
{
	//哪一赛季的。为赛季的起始日期，例如20250901
	int intDay:1;
};
