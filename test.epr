//一些配置，进房间时发
message InitConfig:29  s2c
{
	//场景123的能量等级
	int rollLevelEnergy1:1[];
	int rollLevelEnergy2:2[];
	int rollLevelEnergy3:3[];


	//宝藏碎片：下面4个是时间。格式严格按照："2024/8/28 15:21:0" 或者 空字符串表示服务器完全不支持宝藏碎片玩法。
	//开始时间
	string startPuzzleGameTime:4;
	//结束掉落时间
	string endDropPuzzleGameTime:5;
	//结束兑换时间
	string endRedeemPuzzleGameTime:6;
	//服务器当前时间。防止客户端时间不准或时区问题。
	string serverTime:7;
	//自定义配置
	string userSetting:22;
};

//宝藏碎片：服务器更新玩家宝藏碎片数据。
//如果，服务器不支持宝藏碎片，或者时间已经超过了兑换时间，则永远不会收到这条消息。
//如果支持，玩家进入的时候会收到3条，更新3个场景的消息
//如果支持，下注成功BetSuccess，会收到更新当前的数据。
//如果支持，兑换碎片成功，会收到更新当前的数据。
message UpdatePuzzlePlayerData:30 s2c
{
	//1-3，哪个场景
	char scene:1;
	//9个碎片的数量。6个lv1碎片，2个lv2碎片，1个lv3碎片
	int pieces:2[9];
	//精魄
	int jp:3;
	//100%的精魄
	int jpTotal:4;

	//此场景下，累计的兑换次数
	int smallRedeemCount:5;
	int bigRedeemCount:6;
};

//藏宝碎片：兑换小奖
